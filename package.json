{
  "name": "@razvangeangu/james-smith",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "checkTs": "tsc --noEmit",
    "dev": "next dev --turbopack",
    "knip": "knip",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prepare": "is-ci || husky",
    "prettify": "prettier --write .",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "npm run lint:fix"
    ],
    "*.{md,json}": [
      "npm run prettify"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@base-ui/react": "1.4.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "leaflet": "1.9.4",
    "lucide-react": "1.8.0",
    "motion": "12.38.0",
    "next": "16.2.4",
    "next-intl": "4.9.1",
    "next-themes": "0.4.6",
    "radix-ui": "1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "shadcn": "4.3.0",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/eslintrc": "3.3.5",
    "@tailwindcss/postcss": "4.2.2",
    "@types/jsdom": "28.0.1",
    "@types/leaflet": "1.9.21",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-import-resolver-typescript": "3.10.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "husky": "9.1.7",
    "is-ci": "4.1.0",
    "jsdom": "29.0.2",
    "knip": "6.4.1",
    "lint-staged": "16.4.0",
    "postcss": "8.5.10",
    "postcss-load-config": "6.0.1",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.7.2",
